{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/fraud-check/payments",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.[?(@.amount == 500)]"
      }
    ]
  },
  "response": {
    "status": 500,
    "body": "{\"error\": \"Internal Server Error\", \"message\": \"Upstream fraud service error\"}",
    "delayDistribution": {
      "type": "uniform",
      "lower": 500,
      "upper": 3000
    },
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
