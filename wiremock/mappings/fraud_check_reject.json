{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/fraud-check/payments",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.[?(@.amount == 999)]"
      }
    ]
  },
  "response": {
    "status": 200,
    "body": "{\"checkId\": \"{{randomValue type='UUID'}}\", \"result\": \"REJECT\"}",
    "transformers": ["response-template"],
    "delayDistribution": {
      "type": "uniform",
      "lower": 500,
      "upper": 3000
    },
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
