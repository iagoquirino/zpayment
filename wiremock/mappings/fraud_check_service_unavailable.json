{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/fraud-check/payments",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.[?(@.amount == 503)]"
      }
    ]
  },
  "response": {
    "status": 503,
    "body": "{\"error\": \"Service Unavailable\", \"message\": \"Fraud check service is currently unavailable\"}",
    "delayDistribution": {
      "type": "uniform",
      "lower": 500,
      "upper": 3000
    },
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
